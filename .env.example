# Remote Database Connection (source database)
REMOTE_DATABASE_URL=postgres://user:password@host:5432/dbname

# Local Database Connection (clone for testing)
LOCAL_DATABASE_URL=postgres://user:password@localhost:5432/dbname_local

# Path to schema files (relative to project root)
SCHEMA_PATH=../../schema

# Path to migrations directory
MIGRATIONS_PATH=../../migrations

# pgschema binary path (optional, defaults to 'pgschema')
PGSCHEMA_BIN=pgschema

# dbmate binary path (optional, defaults to 'dbmate')
DBMATE_BIN=dbmate
