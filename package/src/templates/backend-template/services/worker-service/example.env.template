# Worker Service Environment Configuration
# Copy this to .env and update the values

# Database Configuration
DATABASE_URL=postgres://{{dbUser}}:{{dbPassword}}@db:5432/{{projectName}}_db?sslmode=disable

# Worker Configuration
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL=5000
WORKER_SCHEMA=graphile_worker
CRONTAB_FILE=./crontab

# Logging
LOG_LEVEL=info
NODE_ENV={{nodeEnv}}

# Application Configuration
PROJECT_NAME={{projectName}}