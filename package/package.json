{
  "name": "postkit",
  "version": "1.0.0",
  "description": "CLI tool for initializing PostKit projects with the Appri stack",
  "main": "src/cli/index.js",
  "bin": {
    "postkit": "./src/cli/index.js"
  },
  "preferGlobal": true,
  "files": [
    "src/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "start": "node src/cli/index.js",
    "dev": "node src/cli/index.js start --dev",
    "migrate": "node src/cli/index.js migrate",
    "create:task": "node src/cli/index.js create task",
    "create:function": "node src/cli/index.js create function",
    "migrate:create": "node src/cli/index.js migrate:create",
    "migrate:up": "node src/cli/index.js migrate:up",
    "migrate:down": "node src/cli/index.js migrate:down",
    "migrate:status": "node src/cli/index.js migrate:status"
  },
  "keywords": [
    "cli",
    "postkit",
    "postgresql",
    "postgrest",
    "keycloak",
    "graphile-worker",
    "functions-runtime",
    "docker"
  ],
  "author": "Appri Technologies",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "chalk": "^4.1.2",
    "fs-extra": "^11.2.0",
    "mustache": "^4.2.0",
    "dotenv": "^16.3.1",
    "ora": "^5.4.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dbmate": "^2.21.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}