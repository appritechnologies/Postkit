# ============================================
# PostKit CLI Configuration
# ============================================

# --- Database Module (postkit db) ---
REMOTE_DATABASE_URL=postgres://user:password@host:5432/dbname
LOCAL_DATABASE_URL=postgres://user:password@localhost:5432/dbname_local
# SCHEMA_PATH=           # Optional: relative path to schema files
# MIGRATIONS_PATH=       # Optional: relative path to migrations
# PGSCHEMA_BIN=pgschema  # Optional: path to pgschema binary
# DBMATE_BIN=dbmate      # Optional: path to dbmate binary

# --- Auth Module (postkit auth) ---

# Source Keycloak (export from)
KC_SOURCE_URL=https://your-keycloak.example.com
KC_SOURCE_ADMIN_USER=admin
KC_SOURCE_ADMIN_PASS=your_password
KC_SOURCE_REALM=application

# Target Keycloak (import to)
KC_TARGET_URL=https://your-target-keycloak.example.com
KC_TARGET_ADMIN_USER=admin
KC_TARGET_ADMIN_PASS=your_password

# Directories (relative to project root)
# RAW_EXPORT_DIR=.tmp-config
# CLEAN_OUTPUT_DIR=realm-config

# Output filename
# OUTPUT_FILENAME=pro-application-realm.json

# keycloak-config-cli Docker image
# KC_CONFIG_CLI_IMAGE=adorsys/keycloak-config-cli:6.4.0-24
