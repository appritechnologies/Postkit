{
  "name": "@appritech/postkit",
  "version": "1.0.0",
  "description": "PostKit - Developer toolkit for database management and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "postkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "vendor",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "postkit": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "postkit",
    "migration",
    "database",
    "postgresql",
    "cli",
    "toolkit"
  ],
  "author": "Appri Team",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/appri/postkit.git"
  },
  "homepage": "https://github.com/appri/postkit#readme",
  "bugs": {
    "url": "https://github.com/appri/postkit/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dbmate": "^2.32.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "pg": "^8.14.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
